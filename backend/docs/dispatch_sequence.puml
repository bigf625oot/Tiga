@startuml
participant "Client/API" as Client
participant "DispatchService" as Dispatch
participant "NodeDiscovery" as Discovery
participant "Redis" as Redis
participant "Database" as DB
participant "NodeMonitor (WS)" as WS
participant "HttpClient" as HTTP
participant "Gateway" as Gateway

Client -> Dispatch: dispatch_to_gateway(payload, nodeId)
activate Dispatch

== 1. 节点发现与状态检查 ==
Dispatch -> Discovery: get_node_status(nodeId)
activate Discovery
Discovery -> Redis: get("node:status:{id}")
alt Cache Hit
    Redis --> Discovery: status_json
else Cache Miss
    Discovery -> DB: select status from nodes
    DB --> Discovery: node_record
    Discovery -> Redis: set("node:status:{id}")
end
Discovery --> Dispatch: {status: "online/offline"}
deactivate Discovery

alt Node Offline
    Dispatch -> DB: log_fail(NODE_OFFLINE)
    Dispatch --> Client: Exception(NODE_OFFLINE)
end

== 2. WebSocket 下发 (Primary) ==
Dispatch -> WS: request("cron.add", payload)
activate WS
WS -> Gateway: WebSocket Frame
alt Success (within 3s)
    Gateway --> WS: ACK / Response
    WS --> Dispatch: Result
    Dispatch -> DB: log_success() (optional)
    Dispatch --> Client: Result
else Timeout / Error
    WS --> Dispatch: Timeout / Exception
    Dispatch -> DB: log_fail(WS_SEND/WS_ACK)
    
    == 3. HTTP 下发 (Fallback) ==
    Dispatch -> HTTP: invoke("cron", payload)
    activate HTTP
    HTTP -> Gateway: POST /tools/invoke
    alt Success (within 3s)
        Gateway --> HTTP: 200 OK
        HTTP --> Dispatch: Result
        Dispatch --> Client: Result
    else Error (4xx/5xx/Timeout)
        HTTP --> Dispatch: Exception
        Dispatch -> DB: log_fail(HTTP_SEND/HTTP_RESP)
        Dispatch --> Client: Exception(ALL_FAILED)
    end
    deactivate HTTP
end
deactivate WS

deactivate Dispatch
@enduml